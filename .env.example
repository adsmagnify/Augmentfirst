# Public site URL (no trailing slash). Used for sitemap, robots, and canonical SEO tags.
NEXT_PUBLIC_SITE_URL=https://lp.augmentfirst.com

# Optional: absolute logo URL for HTML emails (defaults to https://lp.augmentfirst.com/augment_first_logo.png when site URL is localhost)
# EMAIL_LOGO_URL=https://lp.augmentfirst.com/augment_first_logo.png

# Zoom (unique meeting links per booking)
# 1. https://marketplace.zoom.us → Develop → Build App → Server-to-Server OAuth
# 2. Add scopes (classic or granular): meeting write + user read for the host
#    e.g. meeting:write:admin, user:read:admin
#    or granular: meeting:write:meeting, user:read:user, user:read:list_users:admin
# 3. Activation → Activate your app
# 4. Copy Account ID, Client ID, Client Secret
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# Zoom login email that hosts meetings (must exist on the Zoom account).
# Often a personal Gmail — check https://zoom.us/profile — NOT always the M365 address.
# Leave blank to auto-use the first active Zoom user on the account.
ZOOM_HOST_EMAIL=

# Microsoft Graph (mail + company calendar invites with the Zoom link)
# App registration needs Application permissions + admin consent:
# - Mail.Send
# - Calendars.ReadWrite
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_SENDER_EMAIL=Vijay.Kanojia@augmentfirst.com

# Vercel KV / Upstash Redis (booking slot holds)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Secret used to sign admin "Confirm this slot" email links
BOOKING_CONFIRM_SECRET=
